{%- comment -%} Star rating snippet {%- endcomment -%}
{%- liquid
  assign rating_value = rating_value | default: 0
  assign rating_count = rating_count | default: nil
  assign rating_size = rating_size | default: 'sm'
  assign show_count = show_count | default: true
-%}
<div class="rating rating-{{ rating_size }}">
  <div class="rating-stars">
    {%- for i in (1..5) -%}
      {%- if i <= rating_value -%}
        <span class="rating-star filled">
          <svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      {%- else -%}
        <span class="rating-star">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if show_count -%}
    <span class="rating-count">{{ rating_value }}{% if rating_count != nil %} ({{ rating_count }}){% endif %}</span>
  {%- endif -%}
</div>
