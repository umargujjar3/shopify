<div class="container" style="padding: 80px 24px;">
  <div class="section-header" style="text-align:center; margin-bottom: 48px;">
    <p class="eyebrow" style="color: var(--color-primary); font-weight:600; letter-spacing:0.1em; text-transform:uppercase; font-size:13px; margin-bottom:12px;">Collections</p>
    <h1 class="h1" style="margin:0;">Shop All Collections</h1>
  </div>

  <div class="grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 32px;">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="collection-card" style="display:block; border-radius: 16px; overflow:hidden; background: var(--color-surface); border: 1px solid var(--color-border); transition: transform 0.3s ease, box-shadow 0.3s ease;">
        <div style="aspect-ratio: 4/3; overflow:hidden; background: var(--color-bg);">
          {%- if collection.image -%}
            <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" style="width:100%; height:100%; object-fit:cover; transition: transform 0.5s ease;" loading="lazy">
          {%- else -%}
            <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: linear-gradient(135deg, var(--color-primary), var(--color-natural-green));">
              {%- render 'icon', icon: 'leaf' -%}
            </div>
          {%- endif -%}
        </div>
        <div style="padding: 24px;">
          <h2 class="h3" style="margin:0 0 8px;">{{ collection.title }}</h2>
          <p style="color: var(--color-text-muted); font-size:14px; margin:0 0 16px;">{{ collection.products_count }} products</p>
          <span style="color: var(--color-primary); font-weight:600; font-size:14px; display:inline-flex; align-items:center; gap:6px;">
            Shop collection
            {%- render 'icon', icon: 'arrow-right' -%}
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}
