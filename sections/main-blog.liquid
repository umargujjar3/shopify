<div class="page-header">
  <div class="container">
    <span class="eyebrow center">The Spinexa Journal</span>
    <h1 class="h1 page-header__title" style="margin-top:16px;">{{ blog.title | default: 'Wellness, Naturally' }}</h1>
    <p class="page-header__subtitle text-pretty">Herbal wisdom, rituals, and practical tips for everyday wellness.</p>
  </div>
</div>

<div class="container" style="padding: var(--section-spacing, 80px) 0;">
  {%- if blog.articles.size > 0 -%}
    <!-- Featured post -->
    {%- assign first_article = blog.articles | first -%}
    <a href="{{ first_article.url }}" class="blog-featured">
      <div class="blog-featured__img">
        {%- if first_article.image -%}
          <img src="{{ first_article.image | image_url: width: 800, height: 500, crop: 'center' }}" alt="{{ first_article.title | escape }}" loading="lazy">
        {%- endif -%}
      </div>
      <div class="blog-featured__content">
        <span class="eyebrow">{{ first_article.tags | first }}</span>
        <h2 class="blog-featured__title">{{ first_article.title }}</h2>
        <p style="margin-top:12px; color: var(--color-text-muted);">{{ first_article.excerpt | strip_html | truncatewords: 30 }}</p>
        <div style="margin-top:20px; display:flex; align-items:center; gap:16px; font-size:12px; color: var(--color-text-muted);">
          <span>{{ first_article.published_at | date: '%b %d, %Y' }}</span>
        </div>
      </div>
    </a>

    <!-- Grid -->
    <div class="blog-grid">
      {%- for article in blog.articles offset: 1 -%}
        <a href="{{ article.url }}" class="blog-card">
          <div class="blog-card__img">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 800, height: 500, crop: 'center' }}" alt="{{ article.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="blog-card__content">
            <span class="blog-card__category">{{ article.tags | first }}</span>
            <h3 class="blog-card__title">{{ article.title }}</h3>
            <p class="blog-card__excerpt text-pretty">{{ article.excerpt | strip_html | truncatewords: 20 }}</p>
            <div class="blog-card__meta">
              {%- render 'icon', icon: 'clock' -%}
              <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="search-empty">
      <h2 class="h3">No articles yet</h2>
      <p style="color: var(--color-text-muted);">Check back soon for wellness tips and herbal wisdom.</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
