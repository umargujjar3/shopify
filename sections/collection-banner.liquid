<div class="collection-page">
  <!-- Hero banner -->
  <section class="collection-hero">
    <div class="container">
      <span class="eyebrow center">{%- render 'icon', icon: 'leaf' -%} {{ section.settings.eyebrow }}</span>
      <h1 class="h1 collection-hero__title">{{ collection.title | default: 'Spinexa Wellness Oils' }}</h1>
      {%- if collection.description != blank -%}
        <p class="collection-hero__subtitle text-pretty">{{ collection.description }}</p>
      {%- endif -%}
    </div>
  </section>

  <!-- Toolbar -->
  <div class="collection-toolbar">
    <div class="container">
      <div class="collection-toolbar__inner">
        <div class="collection-filters">
          <a href="{{ collection.url }}" class="collection-filter active">{{ 'sections.collection.filter_all' | t }}</a>
        </div>

        <div class="collection-sort">
          <button class="collection-sort__btn" type="button">
            {%- render 'icon', icon: 'sliders' -%}
            <span class="hide-mobile">{{ 'sections.collection.sort_by' | t }}</span>
            <span id="sort-label">{{ 'sections.collection.sort_featured' | t }}</span>
            {%- render 'icon', icon: 'chevron-down' -%}
          </button>
          <div class="collection-sort__menu">
            <button class="collection-sort__option active" data-sort="manual">{{ 'sections.collection.sort_featured' | t }}</button>
            <button class="collection-sort__option" data-sort="price-ascending">{{ 'sections.collection.sort_price_asc' | t }}</button>
            <button class="collection-sort__option" data-sort="price-descending">{{ 'sections.collection.sort_price_desc' | t }}</button>
            <button class="collection-sort__option" data-sort="best-selling">{{ 'sections.collection.sort_rating' | t }}</button>
          </div>
          <form id="sort-form" style="display:none;">
            <select id="sort-select" name="sort_by">
              <option value="manual">Featured</option>
              <option value="price-ascending">Price: Low to High</option>
              <option value="price-descending">Price: High to Low</option>
              <option value="best-selling">Top Rated</option>
            </select>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Grid -->
  <div class="container">
    <p class="collection-count" style="padding-top:56px;">{{ collection.products_count }} {{ 'sections.collection.products_count' | t }}</p>
    <div class="collection-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product, lazy: true -%}
      {%- else -%}
        <div class="search-empty">
          <div class="search-empty__icon">{%- render 'icon', icon: 'search-x' -%}</div>
          <h2 class="h3">{{ 'general.search.no_results_title' | t }}</h2>
          <p class="text-pretty" style="max-width:400px; color: var(--color-text-muted);">{{ 'general.search.no_results_text' | t }}</p>
          <a href="/collections/all" class="btn btn-primary" style="margin-top:24px;">{{ 'general.search.browse_all' | t }}</a>
        </div>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="pagination__link">{{ 'general.pagination.prev' | t }}</a>
        {%- else -%}
          <span class="pagination__link pagination__disabled">{{ 'general.pagination.prev' | t }}</span>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
          {%- else -%}
            <span class="pagination__current">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="pagination__link">{{ 'general.pagination.next' | t }}</a>
        {%- else -%}
          <span class="pagination__link pagination__disabled">{{ 'general.pagination.next' | t }}</span>
        {%- endif -%}
      </nav>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Collection" }
  ]
}
{% endschema %}
