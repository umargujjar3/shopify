<section class="section--cream" style="padding-block: var(--section-spacing, 80px);">
  <div class="container">
    <div class="ingredients__grid">
      <!-- Intro -->
      <div class="ingredients__intro">
        <div class="reveal"><span class="eyebrow">{{ section.settings.eyebrow }}</span></div>
        <div class="reveal" style="--reveal-delay:100ms"><h2 class="h2 text-balance">{{ section.settings.title }}</h2></div>
        <div class="reveal" style="--reveal-delay:200ms"><p class="ingredients__p text-pretty">{{ section.settings.subtitle }}</p></div>
        <div class="reveal" style="--reveal-delay:300ms">
          <ul class="ingredients__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature' -%}
                <li class="ingredients__list-item" {{ block.shopify_attributes }}>
                  <span class="ingredients__check">{%- render 'icon', icon: 'check' -%}</span>
                  {{ block.settings.text }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      </div>

      <!-- Cards grid -->
      <div class="ingredients__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'ingredient' -%}
            <div class="ingredient-card reveal" style="--reveal-delay:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
              <div class="ingredient-card__img">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
                {%- else -%}
                  <img src="https://images.pexels.com/photos/1087905/pexels-photo-1087905.jpeg?auto=compress&cs=tinysrgb&w=200&h=200&fit=crop" alt="" loading="lazy">
                {%- endif -%}
              </div>
              <div>
                <h3 class="ingredient-card__title">{{ block.settings.name }}</h3>
                <p class="ingredient-card__desc text-pretty">{{ block.settings.desc }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Pure Botanicals" },
    { "type": "text", "id": "title", "label": "Title", "default": "Ingredients Inspired By Nature" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Every drop of Spinexa is built from cold-pressed botanicals chosen for their soothing, comforting properties — never synthetic fragrances, never parabens." }
  ],
  "blocks": [
    { "type": "ingredient", "name": "Ingredient", "settings": [
      { "type": "text", "id": "name", "label": "Name", "default": "Eucalyptus Oil" },
      { "type": "textarea", "id": "desc", "label": "Description", "default": "Refreshing and clearing, traditionally used to soothe everyday tension." },
      { "type": "image_picker", "id": "image", "label": "Image" }
    ]},
    { "type": "feature", "name": "Feature checkmark", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Cruelty-free & vegan" }
    ]}
  ],
  "presets": [{
    "name": "Ingredients",
    "blocks": [
      { "type": "ingredient", "settings": { "name": "Eucalyptus Oil", "desc": "Refreshing and clearing, traditionally used to soothe everyday tension." } },
      { "type": "ingredient", "settings": { "name": "Lavender Essential Oil", "desc": "Calming and balancing — the cornerstone of any relaxation ritual." } },
      { "type": "ingredient", "settings": { "name": "Wintergreen Extract", "desc": "A warming botanical long valued for comforting active muscles." } },
      { "type": "ingredient", "settings": { "name": "Peppermint Oil", "desc": "Cooling and invigorating, providing a refreshing sensation." } },
      { "type": "ingredient", "settings": { "name": "Jojoba Carrier Oil", "desc": "A nourishing base that closely mirrors the skin's natural oils." } },
      { "type": "ingredient", "settings": { "name": "Vitamin E", "desc": "A protective antioxidant that helps nourish and support the skin." } },
      { "type": "feature", "settings": { "text": "Cruelty-free & vegan" } },
      { "type": "feature", "settings": { "text": "No synthetic fragrances" } },
      { "type": "feature", "settings": { "text": "Cold-pressed extraction" } },
      { "type": "feature", "settings": { "text": "Dermatologist reviewed" } }
    ]
  }]
}
{% endschema %}
