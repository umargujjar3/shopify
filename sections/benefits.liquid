<section class="benefits-section" style="background-color: #faf9f6; padding: 70px 20px; text-align: center; font-family: inherit;">
  <div class="benefits-container" style="max-width: 1200px; margin: 0 auto;">
    
    <div class="benefits-header" style="margin-bottom: 50px;">
      {%- if section.settings.eyebrow != blank -%}
        <span class="benefits-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="benefits-main-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="benefits-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="benefits-grid">
      {%- for block in section.blocks -%}
        <div class="benefit-card" {{ block.shopify_attributes }}>
          
          <div class="benefit-icon-wrapper">
            {%- if block.settings.icon_image != blank -%}
              <img src="{{ block.settings.icon_image | image_url: width: 120 }}" alt="{{ block.settings.title }}" class="benefit-custom-icon">
            {%- else -%}
              <svg class="benefit-default-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18m9-9H3" />
              </svg>
            {%- endif -%}
          </div>

          <h3 class="benefit-card-title">{{ block.settings.title }}</h3>
          <p class="benefit-card-desc">{{ block.settings.desc }}</p>
          
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  /* Eyebrow Style (Small Top Heading) */
  .benefits-eyebrow {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #16a34a; /* Brand Green */
    font-weight: 700;
    margin-bottom: 12px;
  }

  /* Main Section Title */
  .benefits-main-title {
    font-size: 28px;
    font-weight: 700;
    color: #1f2937; /* Dark Slate */
    margin: 0 0 16px 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* Subtitle Description */
  .benefits-subtitle {
    font-size: 14px;
    color: #6b7280; /* Elegant Grey */
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Beautiful Responsive Grid System */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); /* 3 Columns on Desktop */
    gap: 30px;
    margin-top: 20px;
  }

  /* Premium Card Design */
  .benefit-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 40px 30px 35px 30px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
    border: 1px solid rgba(0, 0, 0, 0.02);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Premium Hover Effect */
  .benefit-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(22, 163, 74, 0.08);
    border-color: rgba(22, 163, 74, 0.15);
  }

  /* Perfect Icon Container */
  .benefit-icon-wrapper {
    width: 65px;
    height: 65px;
    background-color: #f0fdf4; /* Light Green background */
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: background-color 0.3s;
  }
  .benefit-card:hover .benefit-icon-wrapper {
    background-color: #16a34a; /* Icon circle turns solid green on hover */
  }

  /* Icon Images & SVGs */
  .benefit-custom-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
    transition: filter 0.3s;
  }
  .benefit-card:hover .benefit-custom-icon {
    filter: brightness(0) invert(1); /* Turns white on hover */
  }

  .benefit-default-svg {
    width: 28px;
    height: 28px;
    color: #16a34a;
    transition: color 0.3s;
  }
  .benefit-card:hover .benefit-default-svg {
    color: #ffffff;
  }

  /* Card Headings */
  .benefit-card-title {
    font-size: 16px;
    font-weight: 600;
    color: #1f2937;
    margin: 0 0 12px 0;
    line-height: 1.4;
  }

  /* Card Paragraphs */
  .benefit-card-desc {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  /* --- RESPONSIVE MOBILE MEDIA QUERIES --- */
  @media (max-width: 991px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 columns for Tablets */
      gap: 20px;
    }
    .benefits-main-title {
      font-size: 24px;
    }
  }

  @media (max-width: 767px) {
    .benefits-section {
      padding: 50px 15px;
    }
    .benefits-grid {
      grid-template-columns: 1fr; /* 1 card per row on mobile—No cutting! */
      gap: 24px;
    }
    .benefit-card {
      padding: 30px 20px;
    }
    .benefits-main-title {
      font-size: 22px;
    }
    .benefits-subtitle {
      font-size: 13px;
    }
  }
</style>

{% schema %}
{
  "name": "Benefits Section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Why Spinexa"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Why Choose Spinexa?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every detail — from ingredient to bottle — is designed to deliver a wellness experience you can feel."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Card Icon Image",
          "info": "Upload a PNG transparent icon (suggested size: 64x64px)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "100% Organic"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Benefit Description",
          "default": "Cold-pressed botanical extracts, crafted with traditional herbal wisdom and modern precision."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Benefits Section",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}