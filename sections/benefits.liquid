<section class="section--cream" style="padding: 70px 0 50px 0; background-color: #fcf9f4; overflow: hidden;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding-inline: 20px;">
    
    <!-- Section Header (Clean spacing and perfect readability) -->
    <div class="section-header" style="text-align: center; margin-bottom: 45px;">
      {%- if section.settings.eyebrow != blank -%}
        <div class="reveal">
          <span class="eyebrow center" style="color: #2d5a27; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; font-size: 0.8rem; display: inline-block; margin-bottom: 12px;">
            {{ section.settings.eyebrow }}
          </span>
        </div>
      {%- endif -%}
      
      <div class="reveal" style="--reveal-delay:100ms">
        <h2 class="h2 section-header__title text-balance" style="color: #1e293b; font-size: 2.2rem; font-weight: 800; margin: 0 0 14px 0; line-height: 1.25; letter-spacing: -0.02em;">
          {{ section.settings.title }}
        </h2>
      </div>
      
      {%- if section.settings.subtitle != blank -%}
        <div class="reveal" style="--reveal-delay:200ms">
          <p class="section-header__subtitle text-pretty" style="color: #64748b; font-size: 0.95rem; max-width: 620px; margin: 0 auto; line-height: 1.6;">
            {{ section.settings.subtitle }}
          </p>
        </div>
      {%- endif -%}
    </div>

    <!-- Perfect Grid Container -->
    <div class="benefits__grid">
      {%- for block in section.blocks -%}
        {%- assign has_image = false -%}
        {%- if block.settings.image != blank -%}
          {%- assign has_image = true -%}
        {%- endif -%}

        <div class="benefit-card reveal" 
             style="--reveal-delay:{{ forloop.index0 | times: 100 }}ms; 
                    position: relative; 
                    min-height: 280px; 
                    display: flex; 
                    flex-direction: column; 
                    justify-content: flex-end; 
                    padding: 24px; 
                    border-radius: 16px; 
                    overflow: hidden; 
                    background: {% if has_image %}transparent{% else %}#ffffff{% endif %};
                    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
                    border: 1px solid rgba(0,0,0,0.04);
                    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease, border-color 0.3s ease;
                    color: {% if has_image %}#ffffff{% else %}#334155{% endif %};" 
             {{ block.shopify_attributes }}>
          
          {%- if has_image -%}
            <!-- Premium Image Scaling -->
            <img src="{{ block.settings.image | image_url: width: 600 }}" 
                 alt="{{ block.settings.title | escape }}" 
                 style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; border-radius: 16px;"
                 loading="lazy">
            <!-- Double-layer dark gradient for ultimate text readability -->
            <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0.85) 100%); z-index: 1; pointer-events: none;"></div>
          {%- endif -%}

          <!-- Content Wrapper -->
          <div style="position: relative; z-index: 2; text-align: left; width: 100%;">
            {%- unless has_image -%}
              <!-- Premium Green Icon Container -->
              <span class="benefit-card__icon" style="color: #2d5a27; background-color: #f0fdf4; width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; font-size: 20px;">
                {%- render 'icon', icon: block.settings.icon -%}
              </span>
            {%- endunless -%}
            
            <h3 class="benefit-card__title" style="font-size: 1.15rem; font-weight: 700; margin: 0 0 10px 0; color: {% if has_image %}#ffffff{% else %}#1e293b{% endif %};">
              {{ block.settings.title }}
            </h3>
            
            <p class="benefit-card__desc text-pretty" style="font-size: 0.88rem; line-height: 1.5; margin: 0; color: {% if has_image %}#f3f4f6{% else %}#475569{% endif %};">
              {{ block.settings.desc }}
            </p>
          </div>

        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  /* Desktop & Large Screen Symmetrical Grid Setup */
  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* Guarantees exactly 4 cards in one row on desktop */
    gap: 24px;
    width: 100%;
  }

  /* Premium Hover Interactions */
  .benefit-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(45,90,39,0.08) !important;
    border-color: rgba(45, 90, 39, 0.15) !important;
  }

  /* Tablet Media Query (2x2 Clean Layout) */
  @media (max-width: 1024px) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr); /* 2 rows of 2 cards */
      gap: 20px;
    }
    .section-header__title {
      font-size: 1.8rem !important;
    }
  }

  /* Mobile Media Query (Single column stack — Zero cutting or overlapping) */
  @media (max-width: 767px) {
    .section--cream {
      padding: 50px 0 35px 0 !important;
    }
    .benefits__grid {
      grid-template-columns: 1fr !important; /* 1 perfect card per row */
      gap: 18px;
    }
    .benefit-card {
      min-height: 250px !important;
      padding: 20px !important;
    }
    .section-header__title {
      font-size: 1.6rem !important;
    }
    .section-header__subtitle {
      font-size: 0.88rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Benefits",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Spinexa" },
    { "type": "text", "id": "title", "label": "Title", "default": "Care That Works With Your Body" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Every detail — from ingredient to bottle — is designed to deliver a wellness experience you can feel." }
  ],
  "blocks": [
    { 
      "type": "benefit", 
      "name": "Benefit Card", 
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Select Background Image", "info": "Agar aap yahan image lagayenge to card par image overlay ban jayega." },
        { "type": "select", "id": "icon", "label": "Icon (Only if image is empty)", "default": "sprout", "options": [
          { "value": "sprout", "label": "Sprout" },
          { "value": "wind", "label": "Wind" },
          { "value": "sun", "label": "Sun" },
          { "value": "gem", "label": "Gem" },
          { "value": "leaf", "label": "Leaf" },
          { "value": "shield", "label": "Shield" },
          { "value": "award", "label": "Award" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Herbal Formula" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "Cold-pressed botanical extracts, crafted with traditional herbal wisdom and modern precision." }
      ]
    }
  ],
  "presets": [{
    "name": "Benefits",
    "blocks": [
      { "type": "benefit", "settings": { "icon": "sprout", "title": "Herbal Formula", "desc": "Cold-pressed botanical extracts, crafted with traditional herbal wisdom and modern precision." } },
      { "type": "benefit", "settings": { "icon": "wind", "title": "Relaxing Experience", "desc": "A calming aromatic ritual that helps you unwind, release tension, and find your moment of calm." } },
      { "type": "benefit", "settings": { "icon": "sun", "title": "Everyday Wellness", "desc": "Designed for daily use — a simple, versatile addition to your morning and evening routine." } },
      { "type": "benefit", "settings": { "icon": "gem", "title": "Premium Quality", "desc": "Meticulously sourced ingredients and premium packaging you will be proud to display." } }
    ]
  }]
}
{% endschema %}