<section style="padding: 60px 0; background: #fdfaf6;">
  <div class="container">
    <div style="text-align: center; margin-bottom: 40px;">
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
      {% for block in section.blocks %}
        <div style="position: relative; height: 300px; border-radius: 15px; overflow: hidden; display: flex; align-items: flex-end; padding: 20px;">
          
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" style="position: absolute; top:0; left:0; width:100%; height:100%; object-fit: cover;">
          {% else %}
            <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: #ccc;"></div>
          {% endif %}
          
          <div style="position: relative; z-index: 1; background: rgba(0,0,0,0.5); padding: 15px; width: 100%; border-radius: 10px; color: white;">
            <h3 style="margin: 0; color: #fff;">{{ block.settings.title }}</h3>
            <p style="margin: 5px 0 0; color: #eee;">{{ block.settings.desc }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spinexa Benefits",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Why Spinexa" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Natural relief for your spine." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Select Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Natural Healing" },
        { "type": "text", "id": "desc", "label": "Description", "default": "Herbal medicine for spine pain." }
      ]
    }
  ],
  "presets": [{ "name": "Spinexa Benefits" }]
}
{% endschema %}