<div class="customer-page">
  <div class="customer-card">
    <h1 class="h2 customer-card__title">Login</h1>
    <p class="customer-card__subtitle">Welcome back to Spinexa</p>

    {%- form 'customer_login', class: 'customer-form' -%}
      {%- if form.errors -%}
        <div style="color: #C0392B; font-size:14px; padding:12px; border-radius:12px; background: color-mix(in srgb, #C0392B 8%, transparent); margin-bottom:16px;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="customer-form__field">
        <label class="customer-form__label">Email</label>
        <input type="email" name="customer[email]" class="input" required>
      </div>
      <div class="customer-form__field">
        <label class="customer-form__label">Password</label>
        <input type="password" name="customer[password]" class="input" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block customer-form__submit">Sign in</button>
    {%- endform -%}

    <p class="customer-card__footer">
      New here? <a href="{{ routes.account_register_url }}">Create an account</a>
    </p>
    <p class="customer-card__footer">
      <a href="{{ routes.account_recover_url }}">Forgot password?</a>
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}
