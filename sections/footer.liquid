<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__grid">
        <div class="footer__brand">
          <a href="{{ routes.root_url }}" class="logo logo--light">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}" 
                   alt="{{ shop.name }}" 
                   style="max-width: {{ section.settings.logo_width }}px; display: block; height: auto;"
                   loading="lazy">
            {%- else -%}
              <span class="logo__text">Organics<span class="logo__accent">FU</span></span>
            {%- endif -%}
          </a>
          <p class="footer__about">{{ 'sections.footer.about_text' | t }}</p>
          <div class="footer__social">
            {%- if settings.social_instagram != blank -%}
              <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="{{ 'general.social.instagram' | t }}">{%- render 'icon', icon: 'instagram' -%}</a>
            {%- endif -%}
            {%- if settings.social_facebook != blank -%}
              <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="{{ 'general.social.facebook' | t }}">{%- render 'icon', icon: 'facebook' -%}</a>
            {%- endif -%}
            {%- if settings.social_tiktok != blank -%}
              <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="{{ 'general.social.tiktok' | t }}">{%- render 'icon', icon: 'tiktok' -%}</a>
            {%- endif -%}
            {%- if settings.social_twitter != blank -%}
              <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="{{ 'general.social.twitter' | t }}">{%- render 'icon', icon: 'twitter' -%}</a>
            {%- endif -%}
          </div>
        </div>

        <div>
          <h4 class="footer__col-title">{{ 'sections.footer.shop_title' | t }}</h4>
          <div class="footer__col-links">
            <a href="/collections/all" class="footer__col-link">All Products</a>
            {%- for collection in collections -%}
              {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
                <a href="{{ collection.url }}" class="footer__col-link">{{ collection.title }}</a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>

        <div>
          <h4 class="footer__col-title">{{ 'sections.footer.support_title' | t }}</h4>
          <div class="footer__col-links">
            <a href="/pages/contact" class="footer__col-link">{{ 'sections.header.contact' | t }}</a>
            <a href="/pages/faq" class="footer__col-link">{{ 'sections.header.faq' | t }}</a>
            <a href="/pages/shipping-policy" class="footer__col-link">Shipping Policy</a>
            <a href="/pages/refund-policy" class="footer__col-link">Refund Policy</a>
          </div>
        </div>

        <div>
          <h4 class="footer__col-title">{{ 'sections.footer.company_title' | t }}</h4>
          <div class="footer__col-links">
            <a href="/pages/about" class="footer__col-link">{{ 'sections.footer.about_title' | t }}</a>
            <a href="/blogs/journal" class="footer__col-link">{{ 'sections.header.blog' | t }}</a>
            <a href="/pages/privacy-policy" class="footer__col-link">Privacy Policy</a>
          </div>
        </div>
      </div>

      <div class="footer__bottom" style="border-top: 1px solid color-mix(in srgb, #fff 8%, transparent); padding-top: 40px; margin-top: 56px; display:grid; gap:24px; grid-template-columns: 1fr; text-align: left;">
        <div style="display:flex; gap:24px; flex-wrap:wrap;">
          <a href="mailto:organicsfu@gmail.com" class="footer__contact">
            <span class="footer__contact-icon">{%- render 'icon', icon: 'mail' -%}</span>
            organicsfu@gmail.com
          </a>
          <a href="https://wa.me/923307494441" target="_blank" rel="noopener noreferrer" class="footer__contact">
            <span class="footer__contact-icon">{%- render 'icon', icon: 'phone' -%}</span>
            +92 330 7494441
          </a>
          <span class="footer__contact">
            <span class="footer__contact-icon">{%- render 'icon', icon: 'map-pin' -%}</span>
            Lahore, Punjab, Pakistan
          </span>
        </div>
      </div>

      <div class="footer__bottom" style="margin-top: 0;">
        <p class="footer__copyright">© {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.rights' | t }}</p>
        <div class="footer__badges">
          {%- render 'icon', icon: 'leaf' -%}
          <span>{{ 'sections.footer.cruelty_free' | t }}</span>
          <span>·</span>
          <span>{{ 'sections.footer.vegan' | t }}</span>
          <span>·</span>
          <span>{{ 'sections.footer.natural_ingredients' | t }}</span>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Select Footer Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 130,
      "unit": "px",
      "label": "Footer Logo Width"
    }
  ]
}
{% endschema %}