<section class="hero">
  <div class="hero__bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | image_url: width: 1600 }}" alt="" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__blob hero__blob-1"></div>
  <div class="hero__blob hero__blob-2"></div>

  <div class="container">
    <div class="hero__grid">
      <!-- Copy -->
      <div class="hero__copy">
        <div class="reveal">
          <span class="eyebrow">{%- render 'icon', icon: 'leaf' -%} {{ section.settings.eyebrow }}</span>
        </div>
        <div class="reveal" style="--reveal-delay:100ms">
          <h1 class="h-display hero__title text-balance">
            {{ section.settings.title }}
          </h1>
        </div>
        <div class="reveal" style="--reveal-delay:200ms">
          <p class="hero__subtitle text-pretty">{{ section.settings.subtitle }}</p>
        </div>
        <div class="reveal" style="--reveal-delay:300ms">
          <div class="hero__buttons">
            {%- if section.settings.shop_link != blank -%}
              <a href="{{ section.settings.shop_link }}" class="btn btn-primary btn-group">
                {{ section.settings.shop_text }}
                {%- render 'icon', icon: 'arrow-right' -%}
              </a>
            {%- endif -%}
            {%- if section.settings.learn_link != blank -%}
              <a href="{{ section.settings.learn_link }}" class="btn btn-outline">{{ section.settings.learn_text }}</a>
            {%- endif -%}
          </div>
        </div>
        <div class="reveal" style="--reveal-delay:400ms">
          <div class="hero__meta">
            <div class="hero__meta-stars">
              {%- for i in (1..5) -%}
                {%- render 'icon', icon: 'star' -%}
              {%- endfor -%}
            </div>
            <span class="hero__meta-text" style="font-weight:500;">{{ section.settings.rating_text }}</span>
            <span class="hero__meta-divider"></span>
            <span class="hero__meta-text">{{ 'sections.hero.customers_loved' | t }} <strong>{{ section.settings.customers_count }}</strong> {{ 'sections.hero.customers_suffix' | t }}</span>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div class="reveal" style="--reveal-delay:200ms">
        <div class="hero__image-wrap">
          <div class="hero__glow"></div>
          <div class="hero__image">
            {%- if section.settings.product_image != blank -%}
              <img src="{{ section.settings.product_image | image_url: width: 1100, height: 1300, crop: 'center' }}" alt="{{ section.settings.title | escape }}" fetchpriority="high">
            {%- else -%}
              <img src="https://images.pexels.com/photos/4465969/pexels-photo-4465969.jpeg?auto=compress&cs=tinysrgb&w=1100&h=1300&fit=crop" alt="{{ section.settings.title | escape }}" fetchpriority="high">
            {%- endif -%}
          </div>
          {%- if section.settings.price_label != blank -%}
            <div class="hero__floating hero__price-tag">
              <p class="hero__price-label">{{ 'general.products.from' | t }}</p>
              <p class="hero__price-value">{{ section.settings.price_label }}</p>
            </div>
          {%- endif -%}
          <div class="hero__floating hero__chip">
            <div class="hero__chip-inner">
              <span class="hero__chip-icon">{%- render 'icon', icon: 'leaf' -%}</span>
              <div>
                <p class="hero__chip-title">100% Natural</p>
                <p class="hero__chip-sub">Cold-pressed botanicals</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Premium Herbal Wellness" },
    { "type": "text", "id": "title", "label": "Headline", "default": "Natural Wellness Inspired By Nature" },
    { "type": "textarea", "id": "subtitle", "label": "Subheading", "default": "Discover Spinexa Herbal Wellness Oil designed for your everyday comfort routine — crafted with cold-pressed botanicals and modern care." },
    { "type": "text", "id": "shop_text", "label": "Shop button text", "default": "Shop Now" },
    { "type": "url", "id": "shop_link", "label": "Shop button link", "default": "/collections/all" },
    { "type": "text", "id": "learn_text", "label": "Learn button text", "default": "Learn More" },
    { "type": "url", "id": "learn_link", "label": "Learn button link", "default": "/pages/about" },
    { "type": "text", "id": "rating_text", "label": "Rating text", "default": "4.9 / 5" },
    { "type": "text", "id": "customers_count", "label": "Customer count", "default": "1,280+" },
    { "type": "text", "id": "price_label", "label": "Price tag (e.g. Rs. 2,490)", "default": "Rs. 2,490" },
    { "type": "image_picker", "id": "product_image", "label": "Product image" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (botanical)" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
