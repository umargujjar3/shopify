<section class="relative bg-gray-900 text-white min-h-[380px] md:min-h-[480px] flex items-center justify-center overflow-hidden">
  
  <div class="absolute inset-0 z-0">
    {%- if section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
        {%- endif -%}
        <img src="{{ section.settings.image | image_url: width: 2000 }}" 
             alt="{{ section.settings.heading | escape }}" 
             class="w-full h-full object-cover object-center"
             style="display: block; width: 100%; height: 100%;"
             loading="eager">
      </picture>
    {%- else -%}
      <div class="w-full h-full bg-gradient-to-r from-green-900 to-gray-900 opacity-90"></div>
    {%- endif -%}
    
    {%- assign overlay_value = section.settings.overlay_opacity | times: 0.01 -%}
    <div class="absolute inset-0 bg-black" style="opacity: {{ overlay_value }}; pointer-events: none;"></div>
  </div>

  <div class="container relative z-10 mx-auto px-6 py-12 md:py-16 text-center max-w-4xl">
    {%- if section.settings.subheading_top != blank -%}
      <span class="inline-block text-green-400 font-bold tracking-widest text-xs md:text-sm uppercase mb-2">
        {{ section.settings.subheading_top }}
      </span>
    {%- endif -%}
    
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4 leading-tight">
      {{ section.settings.heading }}
    </h1>
    
    <p class="text-base md:text-lg text-gray-200 mb-6 max-w-2xl mx-auto leading-relaxed">
      {{ section.settings.subheading }}
    </p>
    
    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" 
         class="inline-block bg-green-500 hover:bg-green-600 text-white font-bold px-6 py-3 rounded shadow-lg hover:shadow-green-500/20 transition-all duration-200 transform hover:-translate-y-0.5 text-sm md:text-base">
        {{ section.settings.button_text }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Banner Image",
      "info": "Recommended size: 1920x800px"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Banner Image (Optional)",
      "info": "Recommended size: 800x1000px. Khali chorne par desktop image hi show hogi."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "default": 40,
      "unit": "%",
      "label": "Overlay Dark/Shadow Opacity",
      "info": "Text ko zyada clear dikhane ke liye image ko thoda dark karein."
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "subheading_top",
      "label": "Small Top Subheading",
      "default": "100% Organic & Natural"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Premium Organic Supplements"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Main Description",
      "default": "Feel the power of natural organic ingredients crafted for your health."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}