<section class="hero-slider-section" style="position: relative; width: 100%; overflow: hidden; background-color: #ffffff;">
  
  <div class="hero-swiper" style="overflow: hidden; position: relative; width: 100%;">
    <div class="swiper-wrapper" style="display: flex; transition-property: transform; width: 100%;">
      
      {%- for block in section.blocks -%}
        <div class="swiper-slide" style="flex-shrink: 0; width: 100%; position: relative; display: block;" {{ block.shopify_attributes }}>
          
          <a href="{{ block.settings.button_link | default: '/collections/all' }}" style="display: block; width: 100%; height: 100%; text-decoration: none; outline: none;">
            
            <div class="hero-media-container" style="position: relative; width: 100%; overflow: hidden;">
              {%- if block.settings.video_url != blank -%}
                <video style="width: 100%; height: 100%; object-fit: cover; display: block;" autoplay loop muted playsinline>
                  <source src="{{ block.settings.video_url }}" type="video/mp4">
                </video>
              {%- elsif block.settings.image != blank -%}
                <picture style="display: block; width: 100%; height: 100%;">
                  {%- if block.settings.image_mobile != blank -%}
                    <source media="(max-width: 767px)" srcset="{{ block.settings.image_mobile | image_url: width: 800 }}">
                  {%- endif -%}
                  <img src="{{ block.settings.image | image_url: width: 2000 }}" 
                       alt="OrganicsFU Banner" 
                       style="width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;"
                       loading="eager">
                </picture>
              {%- else -%}
                <div style="width: 100%; height: 100%; background: linear-gradient(to right, #052e16, #064e3b);"></div>
              {%- endif -%}

              {%- assign overlay_opacity = block.settings.overlay_opacity | times: 0.01 -%}
              <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: #000000; opacity: {{ overlay_opacity }}; pointer-events: none; z-index: 2;"></div>
            </div>

          </a>

        </div>
      {%- endfor -%}

    </div>

    <div class="swiper-btn-prev">❮</div>
    <div class="swiper-btn-next">❯</div>
    
    <div class="swiper-pagination-dots"></div>
  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.hero-swiper', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-btn-next',
        prevEl: '.swiper-btn-prev',
      },
      pagination: {
        el: '.swiper-pagination-dots',
        clickable: true,
        bulletClass: 'hero-bullet',
        bulletActiveClass: 'hero-bullet-active'
      }
    });
  });
</script>

<style>
  /* 100% Seamless Aspect Ratio setup */
  .hero-media-container {
    width: 100%;
    height: 42vh; /* Perfect height balance for Desktop banner image */
    min-height: 280px;
  }

  /* Navigation Arrows Styling */
  .swiper-btn-prev, .swiper-btn-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    cursor: pointer;
    background: rgba(0,0,0,0.3);
    padding: 12px 16px;
    border-radius: 50%;
    color: #fff;
    transition: all 0.2s ease;
    display: none;
    user-select: none;
  }
  .swiper-btn-prev { left: 20px; }
  .swiper-btn-next { right: 20px; }

  @media (min-width: 768px) {
    .swiper-btn-prev, .swiper-btn-next {
      display: block !important;
    }
  }
  .swiper-btn-prev:hover, .swiper-btn-next:hover {
    background: rgba(0,0,0,0.6) !important;
  }

  /* Pagination Dots (Beautiful minimal style floating over image) */
  .swiper-pagination-dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    gap: 8px;
  }
  
  .hero-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
  }
  .hero-bullet-active {
    background: #16a34a !important; /* Premium brand green dot */
    width: 22px;
    border-radius: 6px;
  }

  /* Mobile Aspect Ratio Adjustments */
  @media (max-width: 767px) {
    .hero-media-container {
      height: 35vh; /* Responsive height for mobile screens */
      min-height: 200px;
    }
    .swiper-pagination-dots {
      bottom: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Slider / Video",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide (Image or Video)",
      "settings": [
        {
          "type": "header",
          "content": "Video (Recommended for Premium Vibe)"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "MP4 Video Direct Link",
          "info": "Upload video in Shopify 'Files' section, copy URL and paste here."
        },
        {
          "type": "header",
          "content": "Fallback Image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image",
          "info": "1920x800px suggested"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image (Optional)",
          "info": "800x1000px suggested"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 90,
          "step": 10,
          "default": 0,
          "unit": "%",
          "label": "Overlay Shadow Opacity (Keep 0% to keep original colors)"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Click Link",
          "info": "User can click anywhere on the banner to open this link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider / Video",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}