<section class="hero-slider-section" style="position: relative; width: 100%; overflow: hidden; background-color: #ffffff; padding-bottom: 30px;">
  
  <div class="hero-swiper" style="overflow: hidden; position: relative; width: 100%;">
    <div class="swiper-wrapper" style="display: flex; transition-property: transform;">
      
      {%- for block in section.blocks -%}
        <div class="swiper-slide" style="flex-shrink: 0; width: 100%; display: flex; flex-direction: column;" {{ block.shopify_attributes }}>
          
          <div style="position: relative; width: 100%; min-height: 320px; height: 50vh; overflow: hidden;">
            {%- if block.settings.video_url != blank -%}
              <video style="width: 100%; height: 100%; object-fit: cover;" autoplay loop muted playsinline>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- elsif block.settings.image != blank -%}
              <picture>
                {%- if block.settings.image_mobile != blank -%}
                  <source media="(max-width: 767px)" srcset="{{ block.settings.image_mobile | image_url: width: 800 }}">
                {%- endif -%}
                <img src="{{ block.settings.image | image_url: width: 2000 }}" 
                     alt="{{ block.settings.heading | escape }}" 
                     style="width: 100%; height: 100%; object-fit: cover; object-position: center; display: block;"
                     loading="eager">
              </picture>
            {%- else -%}
              <div style="width: 100%; height: 100%; background: linear-gradient(to right, #052e16, #064e3b); opacity: 0.9;"></div>
            {%- endif -%}

            {%- assign overlay_opacity = block.settings.overlay_opacity | times: 0.01 -%}
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: #000000; opacity: {{ overlay_opacity }}; pointer-events: none; z-index: 2;"></div>
          </div>

          <div style="width: 100%; max-width: 800px; margin: 0 auto; padding: 30px 20px; text-align: center; background-color: #ffffff; box-sizing: border-box;">
            {%- if block.settings.subheading_top != blank -%}
              <span style="display: inline-block; color: #16a34a; font-weight: 700; letter-spacing: 0.15em; font-size: 13px; text-transform: uppercase; margin-bottom: 10px;">
                {{ block.settings.subheading_top }}
              </span>
            {%- endif -%}
            
            {%- if block.settings.heading != blank -%}
              <h2 style="font-size: clamp(24px, 3.5vw, 42px); color: #1f2937; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 12px; margin-top: 0; line-height: 1.3; text-transform: uppercase;">
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}
            
            {%- if block.settings.subheading != blank -%}
              <p style="font-size: clamp(14px, 1.6vw, 16px); color: #4b5563; margin-bottom: 24px; line-height: 1.6; max-width: 650px; margin-left: auto; margin-right: auto;">
                {{ block.settings.subheading }}
              </p>
            {%- endif -%}
            
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link | default: '/collections/all' }}" 
                 style="display: inline-block; background-color: #16a34a; color: #ffffff; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 12px 28px; border-radius: 4px; text-decoration: none; font-size: 13px; transition: all 0.3s ease; box-shadow: 0 4px 10px rgba(22, 163, 74, 0.25);">
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}

    </div>

    <div class="swiper-btn-prev" style="position: absolute; left: 16px; top: 25vh; transform: translateY(-50%); z-index: 20; cursor: pointer; background: rgba(0,0,0,0.3); padding: 12px 16px; border-radius: 50%; color: #fff; transition: 0.2s; display: none;">❮</div>
    <div class="swiper-btn-next" style="position: absolute; right: 16px; top: 25vh; transform: translateY(-50%); z-index: 20; cursor: pointer; background: rgba(0,0,0,0.3); padding: 12px 16px; border-radius: 50%; color: #fff; transition: 0.2s; display: none;">❯</div>
    
    <div class="swiper-pagination-dots" style="position: absolute; top: calc(50vh - 30px); left: 50%; transform: translateX(-50%); z-index: 20; display: flex; gap: 8px;"></div>
  </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.hero-swiper', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.swiper-btn-next',
        prevEl: '.swiper-btn-prev',
      },
      pagination: {
        el: '.swiper-pagination-dots',
        clickable: true,
        bulletClass: 'hero-bullet',
        bulletActiveClass: 'hero-bullet-active'
      }
    });
  });
</script>

<style>
  /* Show navigation arrows on desktop */
  @media (min-width: 768px) {
    .swiper-btn-prev, .swiper-btn-next {
      display: block !important;
    }
  }
  .swiper-btn-prev:hover, .swiper-btn-next:hover {
    background: rgba(0,0,0,0.5) !important;
  }
  
  /* Dot styling */
  .hero-bullet {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: background 0.3s;
  }
  .hero-bullet-active {
    background: #16a34a !important;
    width: 24px;
    border-radius: 6px;
  }
</style>

{% schema %}
{
  "name": "Hero Slider / Video",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide (Image or Video)",
      "settings": [
        {
          "type": "header",
          "content": "Video (Recommended for Premium Vibe)"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "MP4 Video Direct Link",
          "info": "Upload video in Shopify 'Files' section, copy URL and paste here. (Keep below 15mb)"
        },
        {
          "type": "header",
          "content": "Fallback Image (If video is empty)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image",
          "info": "1920x800px suggested"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image (Optional)",
          "info": "800x1000px suggested"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 90,
          "step": 10,
          "default": 10,
          "unit": "%",
          "label": "Overlay Shadow Opacity"
        },
        {
          "type": "header",
          "content": "Text Content"
        },
        {
          "type": "text",
          "id": "subheading_top",
          "label": "Small Top Subheading",
          "default": "ORGANICSFU SPECIAL"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Main Heading",
          "default": "Pure Organic Wellness"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Description",
          "default": "Unlock raw nature secrets with cold-pressed pure extracts designed for your body."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Explore Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider / Video",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}