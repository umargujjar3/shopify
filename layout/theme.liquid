<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
    {% endif %}

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
    <meta property="og:url" content="{{ canonical_url }}">
    {%- if page_image -%}
      <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:width" content="1200">
    {%- endif -%}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | escape }}">
    <meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">

    <!-- Preconnects for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Google Fonts: Cormorant Garamond + Plus Jakarta Sans (fallback if Shopify font picker doesn't have them) -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Shopify font faces -->
    {{ settings.font_heading | font_face: font_display: 'swap' }}
    {{ settings.font_body | font_face: font_display: 'swap' }}

    <!-- Stylesheet & scripts -->
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    <!-- Shopify required headers -->
    {{ content_for_header }}

    <!-- CSS variables from theme settings -->
    <style>
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-primary-dark: {{ settings.color_primary_dark }};
        --color-natural-green: {{ settings.color_natural_green }};
        --color-gold: {{ settings.color_gold }};
        --color-background: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-text-muted: {{ settings.color_text_muted }};
        --color-white: {{ settings.color_white }};
        --color-border: {{ settings.color_border }};
        --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
        --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
        --page-width: {{ settings.page_width }}px;
        --header-height: 72px;
      }
    </style>

    <!-- Organization Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        {% if settings.social_instagram != blank %}"sameAs": [{% if settings.social_instagram != blank %}{{ settings.social_instagram | json }}{% endif %}{% if settings.social_facebook != blank %}, {{ settings.social_facebook | json }}{% endif %}{% if settings.social_tiktok != blank %}, {{ settings.social_tiktok | json }}{% endif %}],{% endif %}
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "email": "care@spinexa.com"
        }
      }
    </script>
  </head>

  <body class="template-{{ request.page_type }}">
    <a href="#main" class="skip-link">Skip to content</a>

    {% sections 'header-group' %}

    <main id="main" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% if settings.cart_drawer_enabled %}
      {% render 'cart-drawer' %}
    {% endif %}

    {% if settings.whatsapp_button_enabled %}
      {% render 'whatsapp-button' %}
    {% endif %}

    {% if settings.social_proof_enabled %}
      {% render 'social-proof-popup' %}
    {% endif %}

    {% if settings.newsletter_popup_enabled %}
      {% render 'newsletter-popup' %}
    {% endif %}
  </body>
</html>
